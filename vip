@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800&display=swap');

/* --- Design Tokens & CSS Variables --- */
:root {
  --bg-main: #06040b;
  --bg-card: rgba(16, 11, 28, 0.65);
  --bg-card-hover: rgba(26, 18, 44, 0.85);
  --bg-input: rgba(8, 6, 15, 0.8);
  --bg-nav: rgba(6, 4, 11, 0.75);
  
  --primary: #9d4edd;
  --primary-glow: rgba(157, 78, 221, 0.4);
  --secondary: #e0aaff;
  --accent-neon: #ff007f;
  --accent-neon-glow: rgba(255, 0, 127, 0.45);
  
  --text-main: #f3f0f7;
  --text-muted: #a39cb5;
  --text-dark: #120b22;
  
  --border: rgba(157, 78, 221, 0.2);
  --border-hover: rgba(224, 170, 255, 0.45);
  --border-neon: rgba(255, 0, 127, 0.6);
  
  --shadow-neon: 0 0 20px rgba(157, 78, 221, 0.25);
  --shadow-neon-strong: 0 0 35px rgba(255, 0, 127, 0.4);
  
  --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-normal: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  
  --font-heading: 'Outfit', sans-serif;
  --font-body: 'Inter', sans-serif;
}

/* --- Base & Reset --- */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  scrollbar-gutter: stable;
}

body {
  background-color: var(--bg-main);
  background-image: 
    radial-gradient(circle at 10% 20%, rgba(58, 12, 163, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 90% 80%, rgba(114, 9, 183, 0.15) 0%, transparent 45%),
    radial-gradient(circle at 50% 50%, rgba(15, 10, 30, 0.5) 0%, transparent 100%);
  background-attachment: fixed;
  color: var(--text-main);
  font-family: var(--font-body);
  line-height: 1.6;
  overflow-x: hidden;
}

/* --- Custom Scrollbar --- */
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-track {
  background: var(--bg-main);
}
::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--primary);
  box-shadow: 0 0 8px var(--primary);
}

/* --- Typography --- */
h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: 700;
  letter-spacing: -0.02em;
}

a {
  color: inherit;
  text-decoration: none;
}

/* --- Helper Utilities --- */
.container {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2rem;
}

.text-gradient {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--primary) 50%, var(--accent-neon) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.neon-glow {
  text-shadow: 0 0 10px rgba(157, 78, 221, 0.6), 0 0 20px rgba(157, 78, 221, 0.3);
}

.pulse-badge {
  display: inline-block;
  width: 8px;
  height: 8px;
  background-color: #10b981;
  border-radius: 50%;
  box-shadow: 0 0 8px #10b981;
  animation: pulseGreen 2s infinite;
}

/* --- Animations --- */
@keyframes pulseGreen {
  0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
  70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
}

@keyframes pulseNeon {
  0% { box-shadow: 0 0 10px rgba(157, 78, 221, 0.2); }
  50% { box-shadow: 0 0 25px rgba(157, 78, 221, 0.5); }
  100% { box-shadow: 0 0 10px rgba(157, 78, 221, 0.2); }
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

@keyframes slideInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* --- Header & Navigation --- */
header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background-color: var(--bg-nav);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  transition: padding var(--transition-fast);
}

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80px;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-heading);
  font-size: 1.8rem;
  font-weight: 800;
  color: var(--text-main);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  position: relative;
}

.nav-logo span {
  font-weight: 400;
  color: var(--primary-glow);
}

.nav-menu {
  display: flex;
  gap: 2.5rem;
  list-style: none;
}

.nav-item a {
  font-weight: 500;
  color: var(--text-muted);
  transition: color var(--transition-fast), text-shadow var(--transition-fast);
  font-size: 1rem;
}

.nav-item a:hover, .nav-item.active a {
  color: var(--text-main);
  text-shadow: 0 0 8px var(--primary);
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.server-status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(255, 255, 255, 0.04);
  padding: 0.5rem 1rem;
  border-radius: 50px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  font-size: 0.85rem;
  font-weight: 500;
  cursor: pointer;
  transition: var(--transition-fast);
}

.server-status:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: var(--border-hover);
}

.cart-toggle {
  position: relative;
  background: var(--primary);
  border: none;
  color: var(--text-main);
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.2rem;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  box-shadow: 0 4px 15px rgba(157, 78, 221, 0.3);
}

.cart-toggle:hover {
  transform: scale(1.08);
  box-shadow: 0 4px 20px rgba(157, 78, 221, 0.6);
}

.cart-count {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--accent-neon);
  color: var(--text-main);
  font-size: 0.75rem;
  font-weight: 700;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--bg-main);
}

/* Mobile Menu Button */
.mobile-toggle {
  display: none;
  background: none;
  border: none;
  color: var(--text-main);
  font-size: 1.5rem;
  cursor: pointer;
}

/* --- Hero Section --- */
.hero {
  position: relative;
  padding: 12rem 0 8rem;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 50% 30%, rgba(157, 78, 221, 0.08), transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  max-width: 750px;
  animation: slideInUp 0.8s ease-out;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(157, 78, 221, 0.15);
  border: 1px solid var(--border);
  padding: 0.5rem 1.25rem;
  border-radius: 50px;
  color: var(--secondary);
  font-weight: 600;
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
  box-shadow: var(--shadow-neon);
}

.hero h1 {
  font-size: 4rem;
  line-height: 1.1;
  margin-bottom: 1.5rem;
}

.hero p {
  font-size: 1.2rem;
  color: var(--text-muted);
  margin-bottom: 2.5rem;
  max-width: 650px;
}

.hero-buttons {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 0.9rem 2.2rem;
  font-size: 1rem;
  font-weight: 600;
  border-radius: 12px;
  cursor: pointer;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, #7b2cbf 100%);
  color: var(--text-main);
  border: none;
  box-shadow: 0 4px 20px rgba(157, 78, 221, 0.4);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 25px rgba(157, 78, 221, 0.7);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-main);
  border: 1px solid var(--border);
}

.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--border-hover);
  transform: translateY(-2px);
}

/* --- Features Panel --- */
.features-section {
  padding: 4rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.03);
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  background: rgba(6, 4, 11, 0.4);
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
}

.feature-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2.5rem;
  transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
  backdrop-filter: blur(10px);
}

.feature-card:hover {
  transform: translateY(-5px);
  border-color: var(--border-hover);
  box-shadow: var(--shadow-neon);
}

.feature-icon {
  width: 50px;
  height: 50px;
  background: rgba(157, 78, 221, 0.1);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: var(--primary);
  margin-bottom: 1.5rem;
  border: 1px solid var(--border);
}

.feature-card h3 {
  font-size: 1.35rem;
  margin-bottom: 0.75rem;
}

.feature-card p {
  color: var(--text-muted);
  font-size: 0.95rem;
}

/* --- Shop Section --- */
.shop-section {
  padding: 8rem 0;
}

.section-header {
  text-align: center;
  margin-bottom: 4rem;
}

.section-header h2 {
  font-size: 2.8rem;
  margin-bottom: 1rem;
}

.section-header p {
  color: var(--text-muted);
  font-size: 1.1rem;
  max-width: 600px;
  margin: 0 auto;
}

/* Shop Controls */
.shop-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin-bottom: 3rem;
  background: rgba(16, 11, 28, 0.4);
  padding: 1.25rem 2rem;
  border-radius: 16px;
  border: 1px solid var(--border);
  backdrop-filter: blur(10px);
}

.shop-tabs {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.tab-btn {
  background: transparent;
  border: 1px solid transparent;
  color: var(--text-muted);
  padding: 0.6rem 1.5rem;
  font-size: 0.95rem;
  font-weight: 600;
  border-radius: 50px;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.tab-btn:hover {
  color: var(--text-main);
  background: rgba(255, 255, 255, 0.04);
}

.tab-btn.active {
  background: var(--primary);
  color: var(--text-main);
  border-color: var(--primary);
  box-shadow: 0 0 15px rgba(157, 78, 221, 0.3);
}

.shop-search {
  position: relative;
  max-width: 320px;
  width: 100%;
}

.shop-search input {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--text-main);
  padding: 0.75rem 1rem 0.75rem 2.8rem;
  border-radius: 50px;
  font-size: 0.95rem;
  outline: none;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.shop-search input:focus {
  border-color: var(--border-hover);
  box-shadow: 0 0 15px rgba(157, 78, 221, 0.2);
}

.shop-search i {
  position: absolute;
  left: 1.1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  pointer-events: none;
}

/* Products Grid */
.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 2.5rem;
  min-height: 400px;
}

/* Product Card */
.product-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  overflow: hidden;
  transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
  display: flex;
  flex-direction: column;
  backdrop-filter: blur(10px);
  position: relative;
}

.product-card:hover {
  transform: translateY(-8px);
  border-color: var(--border-hover);
  box-shadow: var(--shadow-neon);
}

.product-card.premium-tag {
  border-color: var(--border-neon);
}

.product-card.premium-tag::after {
  content: 'BEST VALUE';
  position: absolute;
  top: 15px;
  right: 15px;
  background: var(--accent-neon);
  color: var(--text-main);
  font-size: 0.7rem;
  font-weight: 800;
  padding: 0.35rem 0.8rem;
  border-radius: 50px;
  letter-spacing: 0.05em;
  box-shadow: var(--shadow-neon-strong);
  z-index: 10;
}

.product-image-container {
  position: relative;
  height: 220px;
  overflow: hidden;
  background: #110d24;
}

.product-image-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.product-card:hover .product-image-container img {
  transform: scale(1.08);
}

.product-category-badge {
  position: absolute;
  bottom: 15px;
  left: 15px;
  background: rgba(6, 4, 11, 0.75);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--secondary);
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.35rem 0.8rem;
  border-radius: 8px;
  text-transform: uppercase;
}

.product-info {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}

.product-info h3 {
  font-size: 1.4rem;
  margin-bottom: 0.5rem;
  color: var(--text-main);
}

.product-desc {
  font-size: 0.92rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
  flex-grow: 1;
}

.product-specifications {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
  margin-bottom: 1.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
  padding-top: 1.25rem;
}

.spec-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-muted);
}

.spec-item i {
  color: var(--primary);
}

.product-purchase {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
  padding-top: 1.25rem;
  margin-top: auto;
}

.product-price {
  display: flex;
  flex-direction: column;
}

.price-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
}

.price-value {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--text-main);
  font-family: var(--font-heading);
}

.price-value span {
  font-size: 1rem;
  color: var(--text-muted);
  font-weight: 400;
}

.add-to-cart-btn {
  background: rgba(157, 78, 221, 0.1);
  border: 1px solid var(--border);
  color: var(--primary);
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  transition: all var(--transition-fast);
}

.add-to-cart-btn:hover {
  background: var(--primary);
  color: var(--text-main);
  border-color: var(--primary);
  box-shadow: 0 0 15px rgba(157, 78, 221, 0.4);
}

/* --- Shopping Cart Overlay --- */
.cart-sidebar {
  position: fixed;
  top: 0;
  right: -450px;
  width: 450px;
  height: 100%;
  background: rgba(10, 8, 20, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-left: 1px solid var(--border);
  z-index: 1000;
  box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  transition: right var(--transition-normal);
}

.cart-sidebar.open {
  right: 0;
}

.cart-header {
  padding: 2rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-header h2 {
  font-size: 1.6rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.close-cart {
  background: transparent;
  border: none;
  color: var(--text-muted);
  font-size: 1.5rem;
  cursor: pointer;
  transition: color var(--transition-fast);
}

.close-cart:hover {
  color: var(--text-main);
}

.cart-items {
  flex-grow: 1;
  overflow-y: auto;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

/* Cart Item Card */
.cart-item {
  display: flex;
  gap: 1rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.04);
  padding: 1rem;
  border-radius: 12px;
  align-items: center;
}

.cart-item-img {
  width: 70px;
  height: 70px;
  border-radius: 8px;
  overflow: hidden;
  background: #110d24;
}

.cart-item-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cart-item-info {
  flex-grow: 1;
}

.cart-item-info h4 {
  font-size: 1rem;
  margin-bottom: 0.25rem;
}

.cart-item-info .item-price {
  color: var(--secondary);
  font-weight: 600;
  font-size: 0.9rem;
}

.cart-item-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
}

.item-quantity {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 6px;
  padding: 0.25rem 0.5rem;
}

.qty-btn {
  background: transparent;
  border: none;
  color: var(--text-main);
  cursor: pointer;
  width: 18px;
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8rem;
}

.qty-val {
  font-size: 0.85rem;
  font-weight: 600;
  width: 20px;
  text-align: center;
}

.remove-item {
  background: transparent;
  border: none;
  color: rgba(239, 68, 68, 0.7);
  cursor: pointer;
  font-size: 0.9rem;
  transition: color var(--transition-fast);
}

.remove-item:hover {
  color: #ef4444;
}

/* Cart Empty State */
.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--text-muted);
  text-align: center;
  gap: 1rem;
}

.cart-empty i {
  font-size: 3.5rem;
  color: rgba(157, 78, 221, 0.3);
}

/* Cart Footer */
.cart-footer {
  padding: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  background: rgba(6, 4, 11, 0.6);
}

.cart-summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 1.5rem;
  font-size: 1.1rem;
}

.cart-summary-row .total-label {
  color: var(--text-muted);
}

.cart-summary-row .total-price {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--text-main);
  font-family: var(--font-heading);
}

.cart-checkout-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--primary) 0%, #7b2cbf 100%);
  color: var(--text-main);
  border: none;
  font-size: 1.1rem;
  padding: 1rem;
  border-radius: 12px;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 4px 15px rgba(157, 78, 221, 0.3);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
}

.cart-checkout-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(157, 78, 221, 0.6);
}

.cart-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(8px);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-normal);
}

.cart-overlay.show {
  opacity: 1;
  visibility: visible;
}

/* --- FAQ Accordion Section --- */
.faq-section {
  padding: 6rem 0;
  background: rgba(16, 11, 28, 0.25);
  border-top: 1px solid rgba(255, 255, 255, 0.03);
}

.faq-container {
  max-width: 800px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.faq-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.faq-item:hover {
  border-color: var(--border-hover);
}

.faq-question {
  width: 100%;
  background: transparent;
  border: none;
  padding: 1.5rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--text-main);
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 600;
  cursor: pointer;
  text-align: left;
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height var(--transition-normal) ease-in-out;
}

.faq-answer p {
  padding: 0 2rem 1.5rem 2rem;
  color: var(--text-muted);
  font-size: 0.95rem;
}

.faq-item.active .faq-answer {
  max-height: 200px;
}

.faq-question i {
  transition: transform var(--transition-normal);
  color: var(--primary);
}

.faq-item.active .faq-question i {
  transform: rotate(180deg);
}

/* --- Modal Base --- */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-normal);
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(10px);
}

.modal-content {
  position: relative;
  width: 100%;
  max-width: 500px;
  background: #0d091b;
  border: 1px solid var(--border);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), var(--shadow-neon);
  transform: translateY(30px);
  transition: transform var(--transition-normal);
  z-index: 10;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  padding: 2rem 2rem 1rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h3 {
  font-size: 1.5rem;
}

.close-modal {
  background: transparent;
  border: none;
  color: var(--text-muted);
  font-size: 1.5rem;
  cursor: pointer;
}

.close-modal:hover {
  color: var(--text-main);
}

.modal-body {
  padding: 1rem 2rem 2rem 2rem;
}

/* Checkout Form Styles */
.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.form-group input, .form-group select {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--text-main);
  padding: 0.85rem 1.25rem;
  border-radius: 10px;
  font-size: 0.95rem;
  outline: none;
  font-family: var(--font-body);
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.form-group input:focus, .form-group select:focus {
  border-color: var(--border-hover);
  box-shadow: 0 0 10px rgba(157, 78, 221, 0.25);
}

.help-text {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-top: 0.35rem;
  display: block;
}

.card-details-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1rem;
}

.checkout-summary {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 1.25rem;
  margin-bottom: 2rem;
}

.checkout-row {
  display: flex;
  justify-content: space-between;
  font-size: 0.95rem;
  margin-bottom: 0.75rem;
}

.checkout-row:last-child {
  margin-bottom: 0;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  font-weight: 700;
}

/* Success Modal Styles */
.success-anim {
  text-align: center;
  padding: 2rem 0;
}

.success-icon {
  width: 80px;
  height: 80px;
  background: rgba(16, 185, 129, 0.1);
  border: 2px solid #10b981;
  color: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  margin: 0 auto 1.5rem;
  box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
}

.success-anim h4 {
  font-size: 1.6rem;
  margin-bottom: 0.75rem;
}

.success-anim p {
  color: var(--text-muted);
  font-size: 0.95rem;
  margin-bottom: 2rem;
}

/* --- Footer --- */
footer {
  background: #040308;
  border-top: 1px solid rgba(255, 255, 255, 0.03);
  padding: 6rem 0 3rem 0;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr repeat(3, 1fr);
  gap: 4rem;
  margin-bottom: 4rem;
}

.footer-info h3 {
  font-size: 1.8rem;
  margin-bottom: 1.25rem;
}

.footer-info p {
  color: var(--text-muted);
  font-size: 0.95rem;
  margin-bottom: 2rem;
  max-width: 320px;
}

.social-links {
  display: flex;
  gap: 1rem;
}

.social-icon {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  transition: all var(--transition-fast);
}

.social-icon:hover {
  background: var(--primary);
  color: var(--text-main);
  border-color: var(--primary);
  transform: translateY(-3px);
  box-shadow: var(--shadow-neon);
}

.footer-col h4 {
  font-size: 1.1rem;
  margin-bottom: 1.5rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.footer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.footer-links a {
  color: var(--text-muted);
  font-size: 0.95rem;
  transition: color var(--transition-fast);
}

.footer-links a:hover {
  color: var(--text-main);
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.03);
  padding-top: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: 0.85rem;
  color: var(--text-muted);
}

.disclaimer {
  max-width: 600px;
  line-height: 1.5;
}

/* --- Responsive Adjustments --- */
@media (max-width: 1024px) {
  .hero h1 { font-size: 3.2rem; }
  .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 3rem; }
}

@media (max-width: 768px) {
  .navbar { height: 70px; }
  .nav-menu { display: none; }
  .mobile-toggle { display: block; }
  
  .hero { padding: 9rem 0 5rem; }
  .hero h1 { font-size: 2.6rem; }
  .hero p { font-size: 1.1rem; }
  
  .shop-controls { flex-direction: column; align-items: stretch; }
  .shop-search { max-width: 100%; }
  
  .cart-sidebar { width: 100%; right: -100%; }
  .modal-content { max-width: 90%; }
  
  .footer-grid { grid-template-columns: 1fr; gap: 2.5rem; }
}

/* ===================================================
   ADMIN PANEL
   =================================================== */

/* Admin toggle button in navbar */
.admin-toggle-btn {
  background: rgba(255, 165, 0, 0.12);
  border: 1px solid rgba(255, 165, 0, 0.35);
  color: #ffa500;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
}

.admin-toggle-btn:hover {
  background: rgba(255, 165, 0, 0.25);
  box-shadow: 0 0 18px rgba(255, 165, 0, 0.45);
  transform: scale(1.08);
}

/* Overlay behind admin panel */
.admin-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(4px);
  z-index: 1050;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition-normal);
}

.admin-overlay.show {
  opacity: 1;
  pointer-events: all;
}

/* Admin Panel Sidebar */
.admin-panel {
  position: fixed;
  top: 0;
  right: -560px;
  width: 560px;
  height: 100%;
  background: rgba(8, 5, 18, 0.98);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-left: 1px solid rgba(255, 165, 0, 0.2);
  box-shadow: -12px 0 40px rgba(255, 165, 0, 0.08);
  z-index: 1100;
  display: flex;
  flex-direction: column;
  transition: right var(--transition-normal);
  overflow: hidden;
}

.admin-panel.open {
  right: 0;
}

/* Admin Header */
.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.75rem 2rem;
  background: rgba(255, 165, 0, 0.05);
  border-bottom: 1px solid rgba(255, 165, 0, 0.15);
  flex-shrink: 0;
}

.admin-header-left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.admin-header-left > i {
  font-size: 2rem;
  color: #ffa500;
  filter: drop-shadow(0 0 10px rgba(255, 165, 0, 0.5));
}

.admin-header h2 {
  font-size: 1.4rem;
  color: var(--text-main);
  margin: 0;
  line-height: 1.2;
}

.admin-header span {
  font-size: 0.8rem;
  color: #ffa500;
  font-weight: 500;
  opacity: 0.8;
}

.admin-close-btn {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-muted);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  font-size: 1.5rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  line-height: 1;
}

.admin-close-btn:hover {
  background: rgba(255, 0, 0, 0.15);
  border-color: rgba(255, 0, 0, 0.4);
  color: #ff6b6b;
}

/* Admin Tabs */
.admin-tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid rgba(255, 165, 0, 0.12);
  flex-shrink: 0;
}

.admin-tab-btn {
  flex: 1;
  background: transparent;
  border: none;
  border-bottom: 3px solid transparent;
  color: var(--text-muted);
  padding: 1rem 0.5rem;
  font-size: 0.88rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: all var(--transition-fast);
}

.admin-tab-btn:hover {
  color: var(--text-main);
  background: rgba(255, 165, 0, 0.04);
}

.admin-tab-btn.active {
  color: #ffa500;
  border-bottom-color: #ffa500;
  background: rgba(255, 165, 0, 0.06);
}

/* Tab Content Panels */
.admin-tab-content {
  display: none;
  flex: 1;
  overflow-y: auto;
  padding: 1.75rem 2rem;
}

.admin-tab-content.active {
  display: block;
}

/* Section Titles */
.admin-section-title {
  font-size: 0.78rem;
  font-weight: 700;
  color: #ffa500;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.admin-section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(255, 165, 0, 0.15);
}

/* Admin Product List */
#adminProductsList {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.admin-product-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 12px;
  padding: 1rem 1.25rem;
  transition: border-color var(--transition-fast);
}

.admin-product-row:hover {
  border-color: rgba(255, 165, 0, 0.2);
}

.admin-product-row img {
  width: 56px;
  height: 42px;
  object-fit: cover;
  border-radius: 8px;
  background: #110d24;
  flex-shrink: 0;
}

.admin-prod-info {
  flex: 1;
  min-width: 0;
}

.admin-prod-name {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.admin-prod-meta {
  font-size: 0.78rem;
  color: var(--text-muted);
  margin-top: 2px;
}

.admin-prod-price {
  font-size: 1rem;
  font-weight: 700;
  color: #ffa500;
  flex-shrink: 0;
  min-width: 60px;
  text-align: right;
}

.admin-prod-actions {
  display: flex;
  gap: 0.4rem;
  flex-shrink: 0;
}

.admin-edit-btn,
.admin-delete-btn {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 0.85rem;
  transition: all var(--transition-fast);
}

.admin-edit-btn {
  background: rgba(157, 78, 221, 0.1);
  border-color: rgba(157, 78, 221, 0.3);
  color: var(--primary);
}

.admin-edit-btn:hover {
  background: var(--primary);
  color: #fff;
}

.admin-delete-btn {
  background: rgba(255, 70, 70, 0.1);
  border-color: rgba(255, 70, 70, 0.3);
  color: #ff6b6b;
}

.admin-delete-btn:hover {
  background: #ff4646;
  color: #fff;
}

/* Admin Forms */
.admin-settings-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.admin-form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.admin-form-group label {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.admin-form-group input,
.admin-form-group select,
.admin-form-group textarea {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-main);
  padding: 0.75rem 1rem;
  border-radius: 10px;
  font-size: 0.95rem;
  font-family: var(--font-body);
  outline: none;
  width: 100%;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  resize: vertical;
}

.admin-form-group input:focus,
.admin-form-group select:focus,
.admin-form-group textarea:focus {
  border-color: rgba(255, 165, 0, 0.45);
  box-shadow: 0 0 14px rgba(255, 165, 0, 0.12);
}

.admin-form-group select option {
  background: #0f0b1e;
}

.admin-form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}

.admin-save-btn {
  background: linear-gradient(135deg, #ffa500 0%, #e08000 100%);
  border: none;
  color: #000;
  font-size: 0.95rem;
  font-weight: 700;
  padding: 0.85rem 2rem;
  border-radius: 10px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast), opacity var(--transition-fast);
  width: 100%;
}

.admin-save-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(255, 165, 0, 0.35);
}

.admin-save-btn:active {
  transform: translateY(0);
  opacity: 0.9;
}

/* Spec field rows in add product form */
.spec-field-row {
  display: flex;
  gap: 0.6rem;
  align-items: center;
  margin-bottom: 0.6rem;
}

.spec-field-row input {
  flex: 1;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-main);
  padding: 0.6rem 0.85rem;
  border-radius: 8px;
  font-size: 0.88rem;
  font-family: var(--font-body);
  outline: none;
  transition: border-color var(--transition-fast);
}

.spec-field-row input:focus {
  border-color: rgba(255, 165, 0, 0.4);
}

.spec-remove-btn {
  background: rgba(255, 70, 70, 0.1);
  border: 1px solid rgba(255, 70, 70, 0.25);
  color: #ff6b6b;
  width: 34px;
  height: 34px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 0.8rem;
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.spec-remove-btn:hover {
  background: #ff4646;
  color: #fff;
}

.admin-add-spec-btn {
  background: rgba(255, 255, 255, 0.05);
  border: 1px dashed rgba(255, 255, 255, 0.15);
  color: var(--text-muted);
  padding: 0.6rem 1.2rem;
  border-radius: 8px;
  font-size: 0.88rem;
  font-weight: 600;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  transition: all var(--transition-fast);
  width: 100%;
  justify-content: center;
}

.admin-add-spec-btn:hover {
  background: rgba(255, 165, 0, 0.08);
  border-color: rgba(255, 165, 0, 0.3);
  color: #ffa500;
}

/* Edit product inline form */
.admin-edit-form {
  background: rgba(255, 165, 0, 0.05);
  border: 1px solid rgba(255, 165, 0, 0.2);
  border-radius: 12px;
  padding: 1.25rem;
  margin-top: 0.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.admin-edit-form input,
.admin-edit-form textarea,
.admin-edit-form select {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-main);
  padding: 0.6rem 0.9rem;
  border-radius: 8px;
  font-size: 0.9rem;
  font-family: var(--font-body);
  outline: none;
  width: 100%;
  transition: border-color var(--transition-fast);
}

.admin-edit-form input:focus,
.admin-edit-form textarea:focus {
  border-color: rgba(255, 165, 0, 0.45);
}

.admin-edit-form label {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: block;
  margin-bottom: 4px;
}

.admin-edit-save-btn {
  background: linear-gradient(135deg, #ffa500 0%, #e08000 100%);
  border: none;
  color: #000;
  font-weight: 700;
  font-size: 0.88rem;
  padding: 0.6rem 1.5rem;
  border-radius: 8px;
  cursor: pointer;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.admin-edit-save-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 15px rgba(255, 165, 0, 0.35);
}

/* Admin toast notification */
.admin-toast {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: rgba(10, 8, 20, 0.97);
  border: 1px solid rgba(255, 165, 0, 0.35);
  border-radius: 12px;
  padding: 0.9rem 1.75rem;
  color: var(--text-main);
  font-size: 0.95rem;
  font-weight: 600;
  z-index: 9999;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease;
  opacity: 0;
  pointer-events: none;
}

.admin-toast.show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

.admin-toast.success i { color: #10b981; }
.admin-toast.error i { color: #ff6b6b; }
.admin-toast.info i { color: #ffa500; }

/* Responsive Admin Panel */
@media (max-width: 600px) {
  .admin-panel { width: 100%; right: -100%; }
  .admin-form-row { grid-template-columns: 1fr; }
}

/* ===================================================
   NEW FEATURES (RTL, Particles, Reviews Marquee)
   =================================================== */

/* Language Toggle Button */
.lang-toggle-btn {
  background: rgba(157, 78, 221, 0.15);
  border: 1px solid rgba(157, 78, 221, 0.3);
  color: #fff;
  width: 55px;
  height: 40px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: inherit;
  font-weight: 600;
  font-size: 0.9rem;
}

.lang-toggle-btn:hover {
  background: rgba(157, 78, 221, 0.3);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(157, 78, 221, 0.2);
}

/* RTL (Arabic) Support */
body.rtl {
  direction: rtl;
  text-align: right;
  font-family: 'Cairo', 'Tajawal', sans-serif;
}

body.rtl .navbar {
  flex-direction: row-reverse;
}

body.rtl .nav-actions {
  flex-direction: row-reverse;
}

body.rtl .hero-buttons,
body.rtl .shop-controls {
  flex-direction: row-reverse;
}

body.rtl .feature-card {
  text-align: right;
}

body.rtl .feature-icon {
  margin: 0 0 1rem auto;
}

body.rtl .faq-question {
  text-align: right;
}

body.rtl .faq-toggle {
  margin-left: 0;
  margin-right: auto;
}

body.rtl .admin-prod-info {
  margin-left: 0;
  margin-right: 15px;
  text-align: right;
}

/* Particles Container */
#particles-js {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
}

/* Reviews Marquee Section */
.reviews-section {
  padding: 4rem 0;
  background: linear-gradient(180deg, var(--bg-dark) 0%, rgba(157, 78, 221, 0.05) 100%);
  overflow: hidden;
}

.marquee-container {
  width: 100%;
  overflow: hidden;
  position: relative;
  display: flex;
  padding: 1rem 0;
}

.marquee-container::before,
.marquee-container::after {
  content: "";
  position: absolute;
  top: 0;
  width: 150px;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.marquee-container::before {
  left: 0;
  background: linear-gradient(to right, var(--bg-dark), transparent);
}

.marquee-container::after {
  right: 0;
  background: linear-gradient(to left, var(--bg-dark), transparent);
}

.marquee-content {
  display: flex;
  gap: 2rem;
  animation: scrollMarquee 35s linear infinite;
  white-space: nowrap;
}

.marquee-container:hover .marquee-content {
  animation-play-state: paused;
}

@keyframes scrollMarquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.review-card {
  background: rgba(30, 25, 54, 0.6);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  min-width: 320px;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  backdrop-filter: blur(10px);
  white-space: normal;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.review-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 20px rgba(157, 78, 221, 0.15);
  border-color: rgba(157, 78, 221, 0.5);
}

.review-stars {
  color: #ffb703;
  font-size: 0.9rem;
}

.review-text {
  color: var(--text-muted);
  font-size: 0.95rem;
  line-height: 1.5;
  font-style: italic;
}

.review-author {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: auto;
}

.review-author img {
  width: 35px;
  height: 35px;
  border-radius: 50%;
  border: 2px solid var(--primary);
}

.review-author-info {
  display: flex;
  flex-direction: column;
}

.review-author-name {
  color: #fff;
  font-weight: 600;
  font-size: 0.9rem;
}

.review-author-role {
  color: var(--primary);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
